{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" }
      },
      "required": ["uid", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "A sustainable home essential product",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the product" },
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product description" },
        "price": { "type": "number", "description": "Product price" },
        "image": { "type": "string", "description": "Product image URL" },
        "materials": { "type": "array", "items": { "type": "string" }, "description": "List of materials" },
        "dimensions": { "type": "string", "description": "Product dimensions" },
        "category": { "type": "string", "description": "Product category" },
        "color": { "type": "string", "description": "Product color" },
        "rating": { "type": "number", "description": "Average rating" },
        "reviews": { "type": "integer", "description": "Number of reviews" }
      },
      "required": ["id", "name", "price", "image", "category"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "An item in the user's shopping cart",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID of the product" },
        "quantity": { "type": "integer", "description": "Quantity of the product" },
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "image": { "type": "string", "description": "Product image URL" }
      },
      "required": ["id", "quantity"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "An item in the user's wishlist",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID of the product" },
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "image": { "type": "string", "description": "Product image URL" }
      },
      "required": ["id"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed purchase order",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the order" },
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "items": { "$ref": "CartItem" }, "description": "List of items in the order" },
        "total": { "type": "number", "description": "Total order amount" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order creation timestamp" },
        "shippingAddress": { "type": "object", "description": "Shipping address details" }
      },
      "required": ["id", "userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/users/{userId}/cart/{productId}": {
      "schema": "CartItem",
      "description": "User's shopping cart items"
    },
    "/users/{userId}/wishlist/{productId}": {
      "schema": "WishlistItem",
      "description": "User's wishlist items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders collection"
    }
  }
}
